{
    "name": "larajax/larajax",
    "description": "A small AJAX framework for Laravel, built to bring simplicity back to Laravel development.",
    "license": "MIT",
    "type": "library",
    "homepage": "https://larajax.org",
    "authors": [
        {
            "name": "Samuel Georges",
            "email": "sam@daftspunk.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "files": [
            "src/init.php"
        ],
        "psr-4": {
            "Larajax\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larajax\\LarajaxServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
